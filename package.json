{
  "name": "template",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "prepare": "lefthook install",
    "dev": "bun --filter='*' run dev",
    "dev:server": "bun --filter=server run dev",
    "dev:website": "bun --filter=website run dev",
    "dev:dashboard": "bun --filter=dashboard run dev",
    "build": "bun --filter='*' run build",
    "build:server": "bun --filter=server run build",
    "build:website": "bun --filter=website run build",
    "build:dashboard": "bun --filter=dashboard run build",
    "start:server": "bun --filter=server run start",
    "test": "bun --filter='*' run test",
    "test:e2e": "playwright test",
    "test:e2e:report": "playwright show-report playwright-report",
    "check:bundle": "bun scripts/check-bundle-size.ts",
    "seed": "bun --filter=server run seed",
    "deploy:staging": "gh workflow run staging-deploy.yml --ref main && gh run watch",
    "typecheck": "bun --filter='*' run typecheck",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@playwright/test": "^1.59.1",
    "@types/bun": "^1.3.11",
    "@types/node": "^22.13.14",
    "lefthook": "^2.1.4",
    "typescript": "^5"
  },
  "packageManager": "bun@1.3.10"
}
