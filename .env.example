# Copy to .env.development (local dev) or .env.production (VPS server).
# Bun auto-loads .env.<NODE_ENV> at startup. Never commit real values.

# ---------- App ----------
NODE_ENV=development
PORT=3000
DOMAIN=localhost
API_URL=http://localhost:3000
WEBSITE_URL=http://localhost:3001

# Public frontend build URLs.
# NEXT_PUBLIC_API_URL=https://apis.example.com
# NEXT_PUBLIC_SITE_URL=https://shopora-website.pages.dev
# NEXT_PUBLIC_DASHBOARD_URL=https://shopora-dashboard.pages.dev
# VITE_API_URL=https://apis.example.com
# VITE_WEBSITE_URL=https://shopora-website.pages.dev

# ---------- Auth ----------
# 32+ random chars. Generate: openssl rand -base64 48
JWT_SECRET=change-me-min-32-chars-use-openssl-rand-base64-48

# ---------- Database ----------
MONGO_USER=admin
MONGO_PASSWORD=password
MONGO_URI=mongodb://admin:password@localhost:27017/shopora?authSource=admin

# ---------- Cache ----------
REDIS_PASSWORD=devpassword
REDIS_URL=redis://:devpassword@localhost:6379

# ---------- Payments ----------
# Stripe test secret key for hosted Checkout sessions.
# STRIPE_SECRET_KEY=sk_test_...

# ---------- CORS (production) ----------
# Comma-separated list of allowed HTTPS origins. Falls back to https://www.${DOMAIN} etc. if unset.
# CORS_ORIGINS=https://shopora-website.pages.dev,https://shopora-dashboard.pages.dev

# ---------- Storage ----------
STORAGE_PATH=./storage

# ---------- VPS only (production deploy) ----------
# ACME_EMAIL=you@example.com
# GITHUB_OWNER=your-github-username
