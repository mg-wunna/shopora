{
  "name": "server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --env-file=../../.env.development --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun --packages external",
    "start": "bun --env-file=../../.env.production dist/index.js",
    "seed": "bun --env-file=../../.env.development src/seed.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@template/api": "workspace:*",
    "@template/configs": "workspace:*",
    "@orpc/contract": "^1.12.2",
    "@orpc/openapi": "^1.12.2",
    "@orpc/server": "^1.12.2",
    "@orpc/zod": "^1.12.2",
    "bcryptjs": "^2.4.3",
    "hono": "^4.8.2",
    "hono-rate-limiter": "^0.5.3",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.14.1",
    "stripe": "^22.1.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/bun": "^1.3.11",
    "@types/jsonwebtoken": "^9.0.7",
    "typescript": "^5"
  }
}
